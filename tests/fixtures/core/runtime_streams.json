      "\rSTATUS=waiting | BLOCKER=approval | NEXT=approve\n"
    ],
    "expected_output": [
      "STATUS=waiting | BLOCKER=approval | NEXT=approve"
    ],
    "expected_partial": "",
    "expected_visible_partial": null
  },
  {
    "name": "backspace_repaired_provider_event",
    "chunks": [
      "question.askedd\b\n"
    ],
    "expected_output": [
      "question.asked"
    ],
    "expected_partial": "",
    "expected_visible_partial": null
  },
  {
    "name": "split_json_provider_event_survives_chunking",
    "chunks": [
      "{\"type\":\"permission.",
      "asked\",\"properties\":{\"pattern\":\"bash\"}}\n"
    ],
    "expected_output": [
      "{\"type\":\"permission.asked\",\"properties\":{\"pattern\":\"bash\"}}"
    ],
    "expected_partial": "",
    "expected_visible_partial": null
  },
  {
    "name": "long_tool_partial_stays_visible",
    "chunks": [
