#!/usr/bin/env python3
"""Render checked-in muxboard demo visuals."""

from __future__ import annotations

import html
import os
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
DOCS = ROOT / "docs"
FRAME_DIR = ROOT / "target" / "demo" / "frames"
FONTCONFIG_DIR = ROOT / "target" / "demo" / "fontconfig"
WIDTH = 1200
HEIGHT = 680

COLORS = {
    "page_top": "#172033",
    "page_bottom": "#050814",
    "terminal": "#070b14",
    "chrome": "#111827",
    "panel": "#0f172a",
    "panel_hot": "#152036",
    "line": "#475569",
    "line_hot": "#38bdf8",
    "text": "#f8fafc",
    "muted": "#cbd5e1",
    "dim": "#94a3b8",
    "cyan": "#67e8f9",
    "green": "#34d399",
    "yellow": "#fde047",
    "red": "#fb7185",
    "blue": "#93c5fd",
    "purple": "#c4b5fd",
}

TEXT_STYLES = {
    "title": (COLORS["text"], 28, "800"),
    "subtitle": (COLORS["muted"], 17, "500"),
    "label": (COLORS["blue"], 18, "800"),
    "text": (COLORS["text"], 18, "500"),
    "muted": (COLORS["muted"], 16, "500"),
    "dim": (COLORS["dim"], 15, "500"),
    "cyan": (COLORS["cyan"], 18, "600"),
    "green": (COLORS["green"], 18, "700"),
    "yellow": (COLORS["yellow"], 18, "700"),
    "red": (COLORS["red"], 18, "700"),
    "purple": (COLORS["purple"], 18, "700"),
}

FLEET_BASE = [
    (">!", "agents/codex", "needs you", "approval", "red"),
    (" !", "agents/opencode", "stuck", "retry/skip", "red"),
    (" *", "agents/claude", "working", "tests", "green"),
    (" *", "server/api", "quiet", "healthy", "muted"),
]


def e(value: str) -> str:
    return html.escape(value, quote=True)


def text(
    x: int,
    y: int,
    value: str,
    klass: str = "text",
    size: int | None = None,
    anchor: str | None = None,
) -> str:
    fill, default_size, weight = TEXT_STYLES.get(klass, TEXT_STYLES["text"])
    attrs = [
        f'x="{x}"',
        f'y="{y}"',
        'font-family="ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, monospace"',
        f'font-size="{size if size is not None else default_size}"',
        f'font-weight="{weight}"',
        'font-style="normal"',
        f'fill="{fill}"',
    ]
    if anchor is not None:
        attrs.append(f'text-anchor="{anchor}"')
    return f"  <text {' '.join(attrs)}>{e(value)}</text>\n"


def rect(x: int, y: int, w: int, h: int, fill: str, stroke: str | None = None, rx: int = 14, width: float = 1.5) -> str:
    stroke_attrs = "" if stroke is None else f' stroke="{stroke}" stroke-width="{width}"'
    return f'  <rect x="{x}" y="{y}" width="{w}" height="{h}" rx="{rx}" fill="{fill}"{stroke_attrs}/>\n'


def pill(x: int, y: int, label: str, fill: str, fg: str = "#06111f", w: int | None = None) -> str:
    width = w if w is not None else 22 + len(label) * 11
    return (
        rect(x, y, width, 34, fill, rx=17)
        + f'  <text x="{x + width // 2}" y="{y + 23}" text-anchor="middle" '
        'font-family="ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, monospace" '
        f'font-size="16" font-weight="800" fill="{fg}">{e(label)}</text>\n'
    )


def panel(x: int, y: int, w: int, h: int, title: str, hot: bool = False) -> str:
    fill = COLORS["panel_hot"] if hot else COLORS["panel"]
    stroke = COLORS["line_hot"] if hot else COLORS["line"]
    width = 3 if hot else 1.6
    return rect(x, y, w, h, fill, stroke, width=width) + text(x + 22, y + 34, title, "label")


def fleet_rows(frame: str) -> list[tuple[str, str, str, str, str]]:
    if frame in {"after_continue", "jump"}:
        return [
            (" *", "agents/codex", "working", "approved", "green"),
            (">!", "agents/opencode", "stuck", "retry/skip", "red"),
            (" *", "agents/claude", "working", "tests", "green"),
            (" *", "server/api", "quiet", "healthy", "muted"),
        ]
    if frame in {"mark_send", "review_send"}:
        return [
            ("+*", "agents/codex", "working", "approved", "cyan"),
            ("+*", "agents/claude", "working", "tests", "cyan"),
            (">!", "agents/opencode", "stuck", "retry/skip", "red"),
            (" *", "server/api", "quiet", "healthy", "muted"),
        ]
    return FLEET_BASE


def draw_fleet(frame: str, hot: bool) -> str:
    parts = [panel(44, 158, 518, 396, "Fleet | 1-4 / 9 | 2 need you", hot)]
    parts.append(text(70, 214, "   Where             Now          Latest", "dim"))
    y = 254
    for marker, where, now, latest, klass in fleet_rows(frame):
        row_fill = "#1f2937" if marker.startswith(">") else "#0f172a"
        if marker.startswith(">"):
            parts.append(rect(62, y - 24, 474, 34, row_fill, "#334155", rx=8, width=1))
        parts.append(text(78, y, f"{marker} {where}", klass))
        parts.append(text(300, y, now, klass))
        parts.append(text(424, y, latest, klass))
        y += 48
    parts.append(text(70, 510, "+ send list   ! needs you   * active", "dim"))
    return "".join(parts)


def draw_details(frame: str, hot: bool) -> str:
    title = "Details"
    parts = [panel(590, 158, 566, 396, title, hot)]
    if frame in {"after_continue", "jump"}:
        parts.extend(
            [
                text(620, 214, "agents/codex", "text"),
                text(620, 260, "Sent Enter to agents/codex", "green", 22),
                text(620, 302, "State: Working", "green"),
                text(620, 340, "Latest: running approved command", "text"),
                text(620, 398, "Next waiting: agents/opencode", "red"),
                text(620, 456, "Muxboard advances the queue without losing your place.", "muted"),
            ]
        )
    elif frame in {"mark_send", "review_send"}:
        title = "Review send" if frame == "review_send" else "Send list"
        parts[0] = panel(590, 158, 566, 396, title, hot)
        parts.extend(
            [
                text(620, 214, "Targets", "label"),
                pill(620, 236, "agents/codex", COLORS["cyan"], w=156),
                pill(792, 236, "agents/claude", COLORS["cyan"], w=168),
                text(620, 318, "Command", "label"),
                rect(620, 336, 484, 56, "#050814", "#334155", rx=10, width=1.4),
                text(644, 372, "cargo test --all-targets", "text"),
                text(620, 438, "Enter sends after review. Esc cancels.", "yellow", 20),
            ]
        )
    else:
        parts.extend(
            [
                text(620, 214, "agents/codex", "text"),
                text(620, 260, "State: Waiting | Tool: Codex", "yellow"),
                text(620, 302, "Blocked: approval needed", "red"),
                text(620, 344, "Action: a continue", "yellow", 22),
                text(620, 408, "Latest", "label"),
                text(620, 450, "Proposed command: cargo test --all-targets", "text"),
                text(620, 492, "Press Enter or type command to continue", "muted"),
            ]
        )
    return "".join(parts)


def draw_output(hot: bool) -> str:
    parts = [panel(590, 158, 566, 396, "Output", hot)]
    parts.extend(
        [
            text(620, 214, "agents/codex", "text"),
            text(620, 260, "STATUS waiting: approval needed", "yellow"),
            text(620, 302, "Proposed command: cargo test --all-targets", "text"),
            text(620, 344, "Press Enter or type command to continue", "red"),
            text(620, 414, "Output opens inside muxboard.", "green", 22),
            text(620, 458, "Esc returns to the fleet. g jumps to tmux.", "muted"),
        ]
    )
    return "".join(parts)


def draw_jump(hot: bool) -> str:
    parts = [panel(590, 158, 566, 396, "tmux pane", hot)]
    parts.extend(
        [
            text(620, 214, "agents/opencode", "text"),
            text(620, 260, "$ opencode", "cyan"),
            text(620, 304, "I need a human decision:", "yellow"),
            text(620, 348, "1. retry with narrower scope", "text"),
            text(620, 390, "2. skip and keep reviewing", "text"),
            text(620, 456, "g jumps to tmux. muxboard keeps watching.", "green", 20),
        ]
    )
    return "".join(parts)


def draw_right(frame: str, hot: str) -> str:
    if frame == "output":
        return draw_output(hot == "output")
    if frame == "jump":
        return draw_jump(hot == "jump")
    return draw_details(frame, hot == "details")


def frame_svg(step: str, caption: str, frame: str, hot: str, keys: list[str], file_name: str) -> str:
    parts = [
        f'<svg xmlns="http://www.w3.org/2000/svg" width="{WIDTH}" height="{HEIGHT}" '
        f'viewBox="0 0 {WIDTH} {HEIGHT}" role="img" aria-labelledby="title desc">\n',
        '  <title id="title">muxboard demo</title>\n',
        '  <desc id="desc">A high-contrast demo of muxboard showing fleet triage, output inspection, continue, send-list review, and tmux jump.</desc>\n',
        '  <defs>\n',
        '    <linearGradient id="page" x1="0" y1="0" x2="1" y2="1">\n',
        f'      <stop offset="0" stop-color="{COLORS["page_top"]}"/>\n',
        f'      <stop offset="1" stop-color="{COLORS["page_bottom"]}"/>\n',
        '    </linearGradient>\n',
        '    <filter id="shadow" x="-10%" y="-10%" width="120%" height="120%">\n',
        '      <feDropShadow dx="0" dy="18" stdDeviation="22" flood-color="#000000" flood-opacity="0.45"/>\n',
        '    </filter>\n',
        '  </defs>\n',
        f'  <rect width="{WIDTH}" height="{HEIGHT}" fill="url(#page)"/>\n',
        '  <circle cx="1040" cy="70" r="210" fill="#38bdf8" opacity="0.14"/>\n',
        '  <circle cx="120" cy="660" r="230" fill="#34d399" opacity="0.11"/>\n',
        rect(18, 18, 1164, 644, COLORS["terminal"], "#1f2937", rx=26, width=1.6).replace('/>', ' filter="url(#shadow)"/>'),
        rect(18, 18, 1164, 50, COLORS["chrome"], rx=26),
        '  <circle cx="48" cy="43" r="7" fill="#f87171"/>\n',
        '  <circle cx="72" cy="43" r="7" fill="#fbbf24"/>\n',
        '  <circle cx="96" cy="43" r="7" fill="#34d399"/>\n',
        text(600, 49, "muxboard  tmux command center", "dim", 15, "middle"),
        rect(44, 88, 1112, 50, "#101827", "#25324a", rx=14, width=1.4),
        text(68, 122, step, "title"),
        text(430, 121, caption, "subtitle"),
        text(1126, 121, "2 need you, 1 working", "red", 18, "end"),
        draw_fleet(frame, hot == "fleet"),
        draw_right(frame, hot),
        rect(44, 582, 1112, 48, "#101827", "#25324a", rx=14, width=1.4),
    ]
    x = 68
    for key in keys:
        parts.append(pill(x, 589, key, COLORS["yellow"], w=max(72, 28 + len(key) * 12)))
        x += max(82, 38 + len(key) * 12)
    parts.append(text(x + 10, 613, "? help   j/k move   Enter output   g show   Space add   : send   q quit", "muted", 15))
    parts.append(f'  <metadata>{e(file_name)}</metadata>\n')
    parts.append('</svg>\n')
    return "".join(parts)


def write_text(path: Path, source: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(source, encoding="utf-8")
    print(f"Wrote {path.relative_to(ROOT)}")


def fontconfig_env() -> dict[str, str]:
    FONTCONFIG_DIR.mkdir(parents=True, exist_ok=True)
    config = FONTCONFIG_DIR / "fonts.conf"
    config.write_text(
        """<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
  <dir>/System/Library/Fonts</dir>
  <dir>/Library/Fonts</dir>
  <dir>/usr/share/fonts</dir>
  <dir>/usr/local/share/fonts</dir>
  <dir prefix="xdg">fonts</dir>
</fontconfig>
""",
        encoding="utf-8",
    )
    env = os.environ.copy()
    env["FONTCONFIG_FILE"] = str(config)
    return env


def render_gif(frame_paths: list[Path], destination: Path) -> None:
    magick = shutil.which("magick") or shutil.which("convert")
    if magick is None:
        raise SystemExit("Install ImageMagick first, for example: brew install imagemagick.")

    command = [magick, "-background", "#050814"]
    for frame in frame_paths:
        command.extend(["-delay", "115", str(frame)])
    command.extend(["-loop", "0", "-layers", "Optimize", str(destination)])
    subprocess.run(command, check=True, cwd=ROOT, env=fontconfig_env())
    print(f"Wrote {destination.relative_to(ROOT)}")


def main() -> int:
    frames = [
        ("Scan", "see what needs you first", "triage", "fleet", ["j/k"]),
        ("Inspect", "open output without switching panes", "output", "output", ["Enter", "Esc"]),
        ("Act", "continue a waiting agent from the board", "after_continue", "details", ["a"]),
        ("Select", "mark two panes and compose once", "mark_send", "details", ["Space", ":"]),
        ("Review", "confirm before broadcasting to agents", "review_send", "details", ["Enter", "Esc"]),
        ("Jump", "show the pane in tmux for full context", "jump", "jump", ["g"]),
    ]

    FRAME_DIR.mkdir(parents=True, exist_ok=True)
    frame_paths: list[Path] = []
    for index, (step, caption, frame, hot, keys) in enumerate(frames):
        path = FRAME_DIR / f"muxboard-demo-{index + 1}.svg"
        write_text(path, frame_svg(step, caption, frame, hot, keys, path.name))
        frame_paths.append(path)

    write_text(
        DOCS / "muxboard-demo.svg",
        frame_svg(frames[0][0], frames[0][1], frames[0][2], frames[0][3], frames[0][4], "muxboard-demo.svg"),
    )
    render_gif(frame_paths, DOCS / "muxboard-demo.gif")
    return 0


if __name__ == "__main__":
    sys.exit(main())
