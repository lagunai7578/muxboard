  {
    "file": "actions_overlay.txt",
    "journey": "Open More and choose advanced actions without losing the primary path.",
    "protects": "More must expose available power without becoming a vague command palette.",
    "must_show": [
      "muxboard",
      "More",
      "Action: : send this pane",
      "To: demo / agents",
      "send text",
      "browse windows",
      "command center",
      "Start",
      "start agent",
      "show in tmux",
      "? help",
      "Esc close"
    ],
    "must_not_show": [
      "choose action",
      "Smart action",
      "target panes",
      "staged",
      "send to demo / agents"
    ],
    "footer_must_show": [
      "? help",
      "press a listed key",
      "Esc close"
