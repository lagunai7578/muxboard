#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STATE_SCRIPT="$SCRIPT_DIR/muxboard-agent-state"
event="${1:-agent-turn-complete}"
summary="${MUXBOARD_CODEX_SUMMARY:-}"

case "$event" in
    start | session-start | turn-start | working | agent-turn-start)
        state="running"
        ;;
    permission* | approve* | needs-input | input-required | ask-user)
        state="waiting"
        summary="${summary:-approval needed}"
        ;;
    error | fail* | failed)
        state="error"
        summary="${summary:-check output}"
        ;;
    interrupted | stale | stuck)
        state="stuck"
        summary="${summary:-needs review}"
        ;;
    agent-turn-complete | complete | completed | done | stop)
        state="done"
        ;;
    *)
        state="done"
        ;;
esac

exec "$STATE_SCRIPT" --agent codex --state "$state" --summary "$summary"
