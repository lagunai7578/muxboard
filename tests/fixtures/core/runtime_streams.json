[
  {
    "name": "partial_chunks_until_newline",
    "chunks": [
      "hello",
      " world\nsecond line\n"
    ],
    "expected_output": [
      "hello world",
      "second line"
    ],
    "expected_partial": "",
    "expected_visible_partial": null
  },
  {
    "name": "carriage_return_overwrite",
    "chunks": [
      "loading",
      "\rready\n"
    ],
    "expected_output": [
      "ready"
    ],
    "expected_partial": "",
    "expected_visible_partial": null
  },
  {
    "name": "waiting_prompt_stays_visible_without_newline",
    "chunks": [
      "Continue? [y/n]"
    ],
    "expected_output": [],
    "expected_partial": "Continue? [y/n]",
    "expected_visible_partial": "Continue? [y/n]"
  },
  {
    "name": "single_character_echo_stays_hidden",
    "chunks": [
      "c"
    ],
    "expected_output": [],
    "expected_partial": "c",
    "expected_visible_partial": null
  },
  {
    "name": "carriage_return_provider_status_survives_as_complete_line",
    "chunks": [
